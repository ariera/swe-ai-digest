# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
#
# All SMTP_* and FEED_* entries are optional — they override config.yaml when set.
# ANTHROPIC_API_KEY and SMTP_PASSWORD are required.

# ── Required ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
SMTP_PASSWORD=your-smtp-password-here
GITHUB_TOKEN=ghp_...

# ── Email overrides (optional) ─────────────────────────────────────────────────
# EMAIL_BACKEND=smtp        # smtp (default) | file (writes to output/ — no SMTP needed)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_FROM_ADDRESS=digest@example.com
# SMTP_FROM_NAME=SWE AI Digest
# SMTP_ADMIN_ADDRESS=admin@example.com
# SMTP_SUBSCRIBERS_FILE=data/subscribers.yaml

# ── Feed overrides (optional) ──────────────────────────────────────────────────
# FEED_LINK=https://yourusername.github.io/swe-ai-digest/feed.xml
# FEED_PUBLISHER_NAME=SWE AI Digest
# FEED_PUBLISHER_EMAIL=digest@example.com

# ── Anthropic overrides (optional) ────────────────────────────────────────────
# ANTHROPIC_MODEL=claude-sonnet-4-6
